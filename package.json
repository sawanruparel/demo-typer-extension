{
  "name": "demo-typer-extension",
  "version": "1.0.1",
  "description": "Browser extension for realistic typing simulation in demos",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "build": "./build.sh",
    "build:skiptest": "BUILD_SKIP_TEST=1 ./build.sh",
    "publish:webstore": "node scripts/publish-webstore-api.js",
    "publish:webstore:api": "node scripts/publish-webstore-api.js",
    "publish:webstore:dashboard": "node scripts/complete-webstore-dashboard.js",
    "publish:webstore:verify": "node scripts/verify-webstore-public.js",
    "publish:webstore:validate": "node scripts/verify-webstore-public.js",
    "generate-icons": "python3 scripts/generate-icons.py",
    "generate-promo": "node scripts/generate-promo-images.js",
    "generate-screenshots": "node scripts/generate-screenshots.js",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/jest": "^29.5.12",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "playwright": "^1.58.2"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFiles": [
      "./tests/setup.js"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "*.js",
      "!tests/**"
    ]
  }
}
